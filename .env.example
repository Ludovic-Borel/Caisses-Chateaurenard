# ============================================
# Variables d'environnement requises
# ============================================
# Copiez ce fichier en .env pour le développement local
# ET configurez ces mêmes variables dans le dashboard Vercel

# 1. Supabase Project URL
# À trouver dans Supabase Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL="https://votre-projet.supabase.co"

# 2. Supabase Anon / Publishable Key
# À trouver dans Supabase Dashboard → Settings → API → anon public key
VITE_SUPABASE_PUBLISHABLE_KEY="votre-cle-anon-ici"

# 3. Supabase Project ID (extrait de l'URL du projet)
# Exemple: https://supabase.com/dashboard/project/ebrfzqltqpdrnstzmmah
# L'ID est "ebrfzqltqpdrnstzmmah"
VITE_SUPABASE_PROJECT_ID="votre-project-id"

# 4. (Optionnel) Identifiants pour la création automatique des tables
# Nécessaires uniquement si vous voulez que l'app crée les tables automatiquement
# via l'API Management Supabase.
# Ces valeurs ne sont PAS en dur dans le code source.
VITE_SUPABASE_EMAIL="votre-email@exemple.fr"
VITE_SUPABASE_PASSWORD="votre-mot-de-passe"